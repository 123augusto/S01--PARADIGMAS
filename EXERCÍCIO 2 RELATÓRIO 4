package main

import "fmt"

func main() {
	var a, b, c int

	fmt.Println("--- Classificador de Triângulos ---")
	fmt.Print("Digite o lado A: ")
	fmt.Scanln(&a)
	fmt.Print("Digite o lado B: ")
	fmt.Scanln(&b)
	fmt.Print("Digite o lado C: ")
	fmt.Scanln(&c)

	// Verifica se os valores podem formar um triangulo
	if a+b > c && a+c > b && b+c > a {
		// Classificacao usando switch
		switch {
		case a == b && b == c:
			fmt.Println("Equilátero: 3 lados iguais")
		case a == b || a == c || b == c:
			fmt.Println("Isósceles: 2 lados iguais")
		default:
			fmt.Println("Escaleno: todos diferentes")
		}
	} else {
		fmt.Println("Erro: os valores nao formam um triangulo")
	}
}
